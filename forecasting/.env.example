# Kalinga Forecasting — Environment Configuration
# Copy to .env and fill in your values, OR rely on backend/.env, OR
# let the Laravel RunForecasts command pass FORECAST_DATABASE_URL automatically.
#
# Priority: FORECAST_DATABASE_URL > DATABASE_URL > individual DB_* vars > backend/.env

# ── Direct database URL (highest priority) ──────────────────
# FORECAST_DATABASE_URL=postgresql://user:pass@host:5432/db_kalinga?sslmode=require

# ── Or use individual vars (matches backend/.env format) ────
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=db_kalinga
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_SSLMODE=prefer

# ── Forecast Parameters ─────────────────────────────────────
# FORECAST_HORIZON_HOURS=48
# MODEL_VERSION=v0.1
# FORECAST_RETENTION_DAYS=30

# ── Weather (Open-Meteo — free, no key needed) ──────────────
# WEATHER_LAT=14.5995
# WEATHER_LON=120.9842

# ── CORS (FastAPI microservice) ──────────────────────────────
# Comma-separated list of allowed origins for the ML API
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,https://your-production-domain.com
